diff --git a/console/src/styles/ripple-desktop.css b/console/src/styles/ripple-desktop.css
new file mode 100644
index 0000000..b5ed41f
--- /dev/null
+++ b/console/src/styles/ripple-desktop.css
@@ -0,0 +1,37 @@
+/**
+ * AxiMate Ripple — Windows-first desktop shell (active when html.ripple-desktop).
+ */
+html.ripple-desktop,
+html.ripple-desktop body {
+  /* Segoe UI Variable ships on Windows 10+ */
+  font-family:
+    "Segoe UI Variable",
+    "Segoe UI",
+    system-ui,
+    -apple-system,
+    sans-serif;
+  -webkit-font-smoothing: antialiased;
+  text-rendering: optimizeLegibility;
+}
+
+/* Scrollbars: closer to Win11 fluent feel in WebView2 / Electron */
+html.ripple-desktop * {
+  scrollbar-width: thin;
+  scrollbar-color: rgba(120, 120, 120, 0.45) transparent;
+}
+
+html.ripple-desktop *::-webkit-scrollbar {
+  width: 10px;
+  height: 10px;
+}
+
+html.ripple-desktop *::-webkit-scrollbar-thumb {
+  background-color: rgba(120, 120, 120, 0.45);
+  border-radius: 8px;
+  border: 2px solid transparent;
+  background-clip: padding-box;
+}
+
+html.ripple-desktop *::-webkit-scrollbar-thumb:hover {
+  background-color: rgba(90, 90, 90, 0.55);
+}
