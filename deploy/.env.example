# Used by deploy/scripts/bootstrap-server.sh and update-stack.sh
# Copy to deploy/.env on the server.

# --- HiClaw native install (https://github.com/alibaba/hiclaw) ---
# Bundles Higress AI Gateway + Matrix + Manager. CoPaw is used as a Worker runtime inside HiClaw (not a separate stack here).

# 1 = unattended install (required for automation); 0 = interactive wizard
HICLAW_NON_INTERACTIVE=1

# Required when HICLAW_NON_INTERACTIVE=1.
# AxiMate 当前部署约定：使用阿里云「百炼」平台（DashScope）的 API Key，不要用其它厂商 Key。
# 获取方式：登录阿里云百炼 / DashScope 控制台创建 API-KEY。
HICLAW_LLM_API_KEY=

# 与百炼一致（HiClaw 安装脚本默认即为阿里云端点）
HICLAW_LLM_PROVIDER=alibaba-cloud
# HICLAW_DEFAULT_MODEL=qwen3.5-plus
# HICLAW_VERSION=v1.0.9
# HICLAW_PORT_GATEWAY=18080
# HICLAW_PORT_CONSOLE=18001
# HICLAW_PORT_ELEMENT_WEB=18088
# HICLAW_PORT_MANAGER_CONSOLE=18888
# HICLAW_ADMIN_USER=admin
# HICLAW_ADMIN_PASSWORD=
