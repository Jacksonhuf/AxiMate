# Copy to .env next to docker-compose.yml and adjust.
# docker compose automatically loads .env from the current working directory.

# Public hostname or IP (for your notes / client curl examples only; not read by containers)
AXIMATE_PUBLIC_HOST=212.50.255.125

# Published gateway port on the host (default 80)
AXIMATE_GATEWAY_HTTP_PORT=80

# Optional: HTTP Basic auth on /api/orchestrator/ and /api/worker/
# Leave empty to disable.
AXIMATE_GATEWAY_BASIC_USER=
AXIMATE_GATEWAY_BASIC_PASS=

# Optional: require X-API-Key on orchestrator (set same header when calling via gateway)
AXIMATE_ORCH_API_KEY=

AXIMATE_ORCH_LOG_LEVEL=INFO
AXIMATE_WORKER_LOG_LEVEL=INFO
